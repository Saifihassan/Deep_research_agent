# Example environment variables for deep-research-agent
# Copy this file to .env and fill in your real keys/URLs

# API keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
RESEND_APIKEY=your_resend_api_key_here


# Optional email from address
EMAIL_FROM=Acme <onboarding@example.com>

# Debugging flags
OPENAI_DEBUG=false
OAICLIENT_DEBUG=false
